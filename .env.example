# Общие настройки проекта
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# IIKO Cloud API
IIKO_API_LOGIN=your_iiko_cloud_token
IIKO_API_BASE_URL=https://api-ru.iiko.services/api/1
IIKO_WEBHOOK_TOKEN=your_webhook_token

# IIKO OLAP Web
IIKO_BASE_URL=https://your-company.iikoweb.ru
IIKO_USER=your_iiko_login
IIKO_PASSWORD=your_iiko_password

# PremiumBonus
PREMIUM_BONUS_API_URL=https://your-premium-bonus-api
PREMIUM_BONUS_API_KEY=your_premium_bonus_api_key

# Дополнительные параметры меню
IIKO_EXTERNAL_MENU_ID=
IIKO_PRICE_CATEGORY_ID=
IIKO_MENU_LANGUAGE=ru
IIKO_MENU_VERSION=2

# Организации
ORGANIZATIONS=[{"id":"rest-1","name":"Ресторан 1","restaurantId":"123","iikoId":"123","threadId":"0"}]

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
NOTIFY_GROUP=-1000000000000
NOTIFY_THREAD=0
LOGS_GROUP=-1000000000000
LOGS_THREAD=0
ADMIN_IDS=[123456789]
LOG_LEVEL=info